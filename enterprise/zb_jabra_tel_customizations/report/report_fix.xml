<odoo>
    <data>

        <template id="purchase_report_company_fix"
                  inherit_id="purchase.report_purchaseorder">

            <xpath expr="//t[@t-call='web.html_container']" position="before">
                <t t-set="company" t-value="docs and docs[0].company_id"/>
            </xpath>

        </template> 


        <!-- Add Qty Total -->
       <template id="purchase_report_qty_total"
                  inherit_id="purchase.report_purchaseorder_document">

            <xpath expr="//tbody" position="after">
                <tfoot>
                    <tr>
                        <td><strong>Total</strong></td>
                        <td class="text-end">
                            <strong>
                                <t t-esc="sum(line.product_qty for line in o.order_line)"/>
                            </strong>
                        </td>
                        <td colspan="4"/>
                    </tr>
                </tfoot>
            </xpath>

        </template>
       

    </data>
</odoo>
