<odoo>

    <template id="external_layout_jabra">
        <t t-if="not o" t-set="o" t-value="doc"/>

        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id"/>
            </t>
            <t t-elif="o and o.company_id">
                <t t-set="company" t-value="o.company_id"/>
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company"/>
            </t>
        </t>

        <t t-call="zb_jabra_tel_customizations.external_layout_standard_jabra">
            <t t-out="0"/>
        </t>
    </template>


    <template id="external_layout_standard_jabra">

        <!-- HEADER -->
        <div style="border:1px solid #000; padding:10px; margin-bottom:15px;">

            <div style="display:flex; align-items:center;">

                <!-- LEFT (English) -->
                <div style="width:33%; font-size:12px; text-align:left;">
                    <strong><span t-esc="company.name"/></strong><br/>
                    <span t-esc="company.street"/><br/>
                    <span t-esc="company.city"/><br/>
                    <span t-esc="company.country_id.name"/><br/>
                    <t t-if="company.vat">
                        VAT No : <span t-esc="company.vat"/>
                    </t>
                </div>

                <!-- CENTER LOGO -->
                <div style="width:34%; text-align:center;">
                    <img t-if="company.logo"
                         t-att-src="image_data_uri(company.logo)"
                         style="max-height:90px;"
                         alt="Logo"/>
                </div>

                <!-- RIGHT (Arabic) -->
                <div style="width:33%; font-size:12px; text-align:right; direction:rtl;">
                    <strong>
                        <span t-esc="company.company_name_ar or company.name"/>
                    </strong><br/>
                    <span t-esc="company.street"/><br/>
                    <span t-esc="company.city"/><br/>
                    <span t-esc="company.country_id.name"/><br/>
                    <t t-if="company.vat">
                        رقم ضريبي :
                        <span t-esc="company.vat"/>
                    </t>
                </div>

            </div>
        </div>


        <!-- BODY -->
        <div class="article"
             t-att-data-oe-model="o and o._name"
             t-att-data-oe-id="o and o.id">

            <t t-out="0"/>
        </div>


        <!-- FOOTER -->
        <div style="border-top:1px solid #000; margin-top:20px; padding-top:5px; font-size:11px; text-align:center;">
            Page: <span class="page"/> / <span class="topage"/>
        </div>

    </template>


    <!-- ========================= -->
    <!-- 3️⃣ Invoice Report -->
    <!-- ========================= -->
    <template id="report_jabra_invoice">
        <t t-call="web.html_container">
            <t t-call="zb_jabra_tel_customizations.external_layout_jabra">
                <t t-foreach="docs" t-as="o">

                    <main>
                        <div class="page">

                            <h2 style="text-align:center;">
                                Simplified Tax Invoice
                                <span t-field="o.name"/>
                            </h2>

                            <br/>

                            <div>
                                <strong>Customer:</strong>
                                <span t-field="o.partner_id.name"/>
                            </div>

                            <br/>

                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Description</th>
                                        <th>Qty</th>
                                        <th>Unit Price</th>
                                        <th>VAT</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.invoice_line_ids" t-as="line">
                                        <tr>
                                            <td><span t-field="line.name"/></td>
                                            <td><span t-field="line.quantity"/></td>
                                            <td><span t-field="line.price_unit"/></td>
                                            <td>
                                                <span t-esc="line.price_total - line.price_subtotal"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                            <td><span t-field="line.price_total"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <br/>

                            <div style="text-align:right;">
                                <strong>Total:</strong>
                                <span t-field="o.amount_total"/>
                            </div>

                        </div>
                    </main>

                </t>
            </t>
        </t>
    </template>

</odoo>