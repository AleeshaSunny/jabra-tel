<?xml version="1.0"?>
<odoo>
	<record model="ir.ui.view" id="view_move_form_inherit_zb_jabra_tel_customization">
		<field name="name">account.move.form.inherited.zb.jabra.tel.customization</field>
		<field name="model">account.move</field>
		<field name="inherit_id" ref="account.view_move_form" />
		<field name="arch" type="xml">
			<data>
                <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="invoice_date_due" readonly="state == 'posted'" />
            </xpath>
            </data>
        </field>
        </record>

</odoo>